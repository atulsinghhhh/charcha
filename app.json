{
  "expo": {
    "name": "Charcha",
    "slug": "charcha",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/charcha-icon.png",
    "scheme": "charcha",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/charcha-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#208AEF"
    },
    "ios": {
      "icon": "./assets/images/charcha-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/charcha-icon.png",
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "package": "com.atulsinghh.charcha",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/charcha-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location",
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/charcha-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f6f58252-a6a0-4c6e-98b2-11de1bde8da2"
      }
    }
  }
}
